        <DTS:Executable
          DTS:refId="Package\Load Dimesnions\Generate Date_dim"
          DTS:CreationName="Microsoft.ExecuteSQLTask"
          DTS:Description="Execute SQL Task"
          DTS:DTSID="{050E34CB-1B25-4CC9-848C-0D44F1BC4B80}"
          DTS:ExecutableType="Microsoft.ExecuteSQLTask"
          DTS:LocaleID="-1"
          DTS:ObjectName="Generate Date_dim"
          DTS:ThreadHint="0">
          <DTS:Variables />
          <DTS:ObjectData>
            <SQLTask:SqlTaskData
              SQLTask:Connection="{1CA1BA15-9A36-4C1C-836F-5F0ABB4BAC2C}"
              SQLTask:SqlStatementSource="DECLARE @start DATE = '1900-01-01';&#xA;DECLARE @end   DATE = '2026-12-31';&#xA;WHILE @start &lt;= @end&#xA;BEGIN&#xA;    INSERT INTO Date_dim&#xA;    VALUES (&#xA;        CONVERT(INT, FORMAT(@start, 'yyyyMMdd')),&#xA;        @start,&#xA;        DAY(@start),&#xA;        MONTH(@start),&#xA;        DATENAME(MONTH, @start),&#xA;        DATEPART(QUARTER, @start), &#xA;        YEAR(@start),&#xA;        DATEPART(WEEKDAY, @start),&#xA;        DATENAME(WEEKDAY, @start),&#xA;        CASE &#xA;            WHEN DATEPART(WEEKDAY, @start) IN (1,7) THEN 1 &#xA;            ELSE 0 &#xA;        END&#xA;    );&#xA;&#xA;    SET @start = DATEADD(DAY, 1, @start);&#xA;END;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
          </DTS:ObjectData>
        </DTS:Executable>
