                      UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor, Microsoft.DataTransformationServices.Controls, Version=17.0.0.0, Culture=neutral, PublicKeyToken=89845dcd8080cc91">select 
	   d.address_id,
	   d.city,
	   d.street_name,
	   d.street_number,
	   c.country_name,
	   ds.address_status
from address d
	 join country c on c.country_id = d.country_id	
	 join customer_address ca on ca.address_id = d.address_id
	 join address_status ds on ca.status_id = ds.status_id;</property>
